# Copy this file to .env and customise for your deployment.
# docker compose automatically reads .env from the project root.

# ── Optional Basic-Auth ───────────────────────────────────────────────────────
# Leave blank (or remove) to run the dashboard without authentication.
AUTH_USER=
AUTH_PASSWORD=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
